# Gitignore — Ponzivenzo Smart Tracker
# ============================================================

# Environment variables (NEVER commit)
.env
.env.local
.env.*.local

# Credenciales / secretos (NEVER commit)
ponce-benzo-vault/Credenciales Temporales Piloto.md
tools/vendedores.secret.json

# Temporary workbench
.tmp/

# Datos crudos de negocio — solo local, no versionar (ver datos/README.md)
# Se versiona la estructura (README + .gitkeep), NO los archivos de datos.
datos/**/*.xlsx
datos/**/*.xls
datos/**/*.csv

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node / Next.js
hub/node_modules/
hub/.next/
hub/out/
hub/.vercel
node_modules/
mobile/node_modules/

# Expo
mobile/.expo/

# Claude Code / AI tooling (local only)
.claude/
hub/.claude/
.agents/
skills-lock.json
superpowers/

# OS
.DS_Store
Thumbs.db
