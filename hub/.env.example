# Ponzivenzo Smart Tracker — Environment Variables
# Copy this file to .env.local and fill in the real values from Supabase dashboard

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_NAME=Ponzivenzo Smart Tracker

# Service role key — only used in tools/import-data.ts, never exposed to the browser
SUPABASE_SERVICE_ROLE_KEY=

# NOTA: tools/verify_supabase_connection.py lee un .env EN LA RAÍZ del repo
# con: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
